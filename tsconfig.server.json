{
  "compilerOptions": {
    "target": "ES2020",             
    "module": "NodeNext",           
    "moduleResolution": "NodeNext", 
    "outDir": "dist",               
    "rootDir": "./",                
    "strict": true,                 
    "esModuleInterop": true,        
    "forceConsistentCasingInFileNames": true, 
    "skipLibCheck": true,           
    "resolveJsonModule": true,      
    "allowSyntheticDefaultImports": true, 
    "sourceMap": true,              
    "declaration": false            
  },
  "include": [
    "src/server.ts",                  
    "src/routes/**/*.ts",             
    "src/config/**/*.ts",             
    "middleware/**/*.ts",             
    "prisma/**/*.ts",               
    "src/backend/scripts/**/*.ts"     
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/components",                
    "src/contexts",                   
    "src/hooks",                      
    "src/locales",                    
    "src/pages",                      
    "src/styles",                     
    "src/utils",                      
    "src/i18n.ts"                     
  ]
}
