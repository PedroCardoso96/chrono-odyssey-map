# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados (Prisma com SQLite)
# Como você usa o dev.db na pasta prisma/, a URL deve apontar para ele
DATABASE_URL="file:./dev.db"

# Autenticação (JWT)
# Use uma string aleatória para assinar seus tokens
JWT_SECRET="sua_chave_secreta_aqui"

# Integração com Google (Para o GoogleAuthButton)
# Você obtém essas chaves no Google Cloud Console
GOOGLE_CLIENT_ID="seu_client_ID_aqui"
VITE_GOOGLE_CLIENT_ID="seu_client_ID_aqui"
GOOGLE_CLIENT_SECRET="seu_client_ID_secret_aqui"
ADMIN_EMAIL="exemplo@gmail.com"

# Pagamentos (Stripe)
# Obtidas no dashboard do Stripe (Modo de Teste)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Configurações do Frontend (Vite)
# Se o seu front for chamar o back em portas diferentes
VITE_API_URL="http://localhost:3001"


# --- Variáveis para o BUILD DO FRONTEND (Vite) ---
# ✅ ATUALIZADO para a chave de PRODUÇÃO
VITE_STRIPE_PUBLISHABLE_KEY="pk_live_..."
