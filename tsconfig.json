// tsconfig.json
{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext", 
    "moduleResolution": "NodeNext",
    "outDir": "dist",              
    "rootDir": "./",                
    "strict": true,                 
    "esModuleInterop": true,        
    "forceConsistentCasingInFileNames": true, 
    "skipLibCheck": true,           
    "resolveJsonModule": true,      
    "allowSyntheticDefaultImports": true, 
    "sourceMap": true,              
    "declaration": false            
  },
  "ts-node": {
    "esm": true                     
  },
  "include": [
    "src/**/*.ts",                  
    "middleware/**/*.ts"            
    // "src/config/**/*.ts",         
    // "src/prisma/**/*.ts"          
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
