{
  "name": "chrono-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "ts-node-dev --respawn --transpile-only --esm src/server.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "build-backend": "tsc -p tsconfig.server.json",
    "build-frontend": "vite build",
    "build": "rm -rf dist && npm run build-backend && npm run build-frontend",
    "start": "node dist/src/server.js",
	"db:backup": "tsx src/backend/scripts/exportFullData.ts",
    "pipeline": "tsx prisma/DataBasePipeline.ts",
    "db:seed": "tsx prisma/DataBasePipeline.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@prisma/client": "^6.9.0",
    "@react-oauth/google": "^0.12.2",
    "@types/leaflet": "^1.9.18",
    "axios": "^1.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "framer-motion": "^12.23.9",
    "google-auth-library": "^9.15.1",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.0",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "leaflet-minimap": "^3.6.1",
    "lucide-react": "^0.518.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet": "^6.1.0",
    "react-i18next": "^15.5.3",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^6.23.0",
    "react-slick": "^0.30.3",
    "rollup": "^4.41.1",
    "slick-carousel": "^1.8.1",
    "sqlite3": "^5.1.7",
    "stripe": "^18.3.0",
    "zod": "^3.25.67"
  },
  "resolutions": {
    "path-to-regexp": "3.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tsconfig/vite-react": "^6.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.13",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/stripe": "^8.0.417",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5"
